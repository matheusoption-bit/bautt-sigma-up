      "payload": {
        "declividade_media_pct": 12.0,
        "solo_classe": "ARGILOSO",
        "pct_app_area": 3.0
      },
      "expected": {
        "status_code": 422,
        "has_coverage_warning": true
      }
    },
    {
      "id": "FZ-007",
      "category": "insufficient_data",
      "description": "Coverage at exactly 0.3 threshold",
      "payload": {
        "declividade_media_pct": 8.0,
        "solo_classe": null,
        "pct_app_area": null
      },
      "expected": {
        "status_code": 422,
        "has_coverage_warning": true,
        "max_coverage_score": 0.4
      }
    },
    {
      "id": "FZ-008",
      "category": "insufficient_data",
      "description": "Null critical terrain metrics",
      "payload": {
        "overlaps_area_uniao": true,
        "historico_deslizamento_r4": true
      },
      "expected": {
        "status_code": 422,
        "has_coverage_warning": true
      }
    },
    {
      "id": "FZ-009",
      "category": "insufficient_data",
