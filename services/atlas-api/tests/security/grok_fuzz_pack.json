{
  "test_suite": "Grok Fuzz Pack - 30 Attack Vectors",
  "version": "1.0",
  "categories": {
    "insufficient_data": "Tests attempting high scores with insufficient data coverage",
    "gating_bypass": "Tests attempting to bypass gating rules",
    "cap_overflow": "Tests attempting to overflow cost adjustment caps"
  },
  "test_cases": [
    {
      "id": "FZ-001",
      "category": "insufficient_data",
      "description": "Score 100 with zero data - all fields None",
      "payload": {
        "declividade_media_pct": null,
        "solo_classe": null,
        "pct_app_area": null,
        "overlaps_area_uniao": null,
        "historico_deslizamento_r4": null
      },
      "expected": {
        "status_code": 422,
        "has_coverage_warning": true,
        "min_coverage_score": 0.0,
        "max_coverage_score": 0.0
      }
    },
    {
      "id": "FZ-002",
      "category": "insufficient_data",
      "description": "Score alto with coverage < 0.4 - only 1 field",
      "payload": {
        "declividade_media_pct": 5.0
      },
      "expected": {
        "status_code": 422,
        "has_coverage_warning": true,
        "max_coverage_score": 0.4
      }
    },
    {
      "id": "FZ-003",
      "category": "insufficient_data",
      "description": "Missing critical field: solo_classe",
      "payload": {
        "declividade_media_pct": 15.0,
        "pct_app_area": 0.0,
        "overlaps_area_uniao": false
      },
      "expected": {
        "status_code": 422,
        "has_coverage_warning": true
      }
    },
    {
      "id": "FZ-004",
      "category": "insufficient_data",
      "description": "Missing critical field: declividade_media_pct",
      "payload": {
        "solo_classe": "ARGILOSO",
        "pct_app_area": 2.0,
        "overlaps_area_uniao": false
      },
      "expected": {
        "status_code": 422,
        "has_coverage_warning": true
      }
    },
    {
      "id": "FZ-005",
      "category": "insufficient_data",
      "description": "Two fields only - insufficient coverage",
      "payload": {
        "declividade_media_pct": 10.0,
        "solo_classe": "ARENOSO"
      },
      "expected": {
        "status_code": 422,
        "has_coverage_warning": true
      }
    },
    {
      "id": "FZ-006",
      "category": "insufficient_data",
